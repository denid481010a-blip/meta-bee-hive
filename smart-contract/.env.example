# Приватный ключ кошелька деплоера (БЕЗ 0x)
PRIVATE_KEY=your_private_key_here

# Адрес ROOT аккаунта (системный якорь матрицы)
ROOT_ADDRESS=0x...

# Адрес кошелька для получения 10% комиссии системы
SYSTEM_WALLET=0x...

# RPC провайдеры
POLYGON_MUMBAI_RPC=https://rpc-mumbai.maticvigil.com
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# API ключ Polygonscan (для верификации контракта)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Для gas reporter
REPORT_GAS=false
